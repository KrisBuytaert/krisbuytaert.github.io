<script language="JavaScript">
function RandomNumber() {
  today = new Date();
  limits=6;
  num = today.getTime();
  num = Math.round(Math.abs(Math.sin (num)*1000000)) % limits;
  return num;  
}

function initArray() {
      this.length = initArray.arguments.length
      for (var i = 0; i < this.length; i++)
      this[i+1] = initArray.arguments[i]
   }


